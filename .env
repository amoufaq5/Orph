# ===============================
# Orph Environment Variables
# ===============================

# 🔑 API Key (keep secret, don’t commit real one to Git)
ORPH_API_KEY=f4a1c3b9d2e64f18b43a9ef07a97b313d7d80f2e9e9f6a8c23f58a2d4c9e0a12

# Paths
DATA_RAW=data/raw
DATA_CLEAN=data/clean
DATA_SYNTHETIC=data/synthetic
DATA_CLEANERS=data/cleaners
CHECKPOINTS=outputs/checkpoints
LOGS=outputs/logs

# Training
BATCH_SIZE=32
EPOCHS=5
LEARNING_RATE=3e-5
OPTIMIZER=adamw
DEVICE=cuda   # change to "cpu" if no GPU

# Model
MODEL_TYPE=OrphGPT
VOCAB_SIZE=32000
HIDDEN_SIZE=768
NUM_LAYERS=12
NUM_HEADS=12
DROPOUT=0.1

# Logging
LOG_LEVEL=INFO
SAVE_PREDICTIONS=true
SAVE_METRICS=true
